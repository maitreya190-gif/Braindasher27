{
  "name": "braindasher-spectrum-2027",
  "version": "1.0.0",
  "description": "An interactive gaming platform with 5 brain-teasing puzzle games for PCCOE BrainDasher Spectrum 2027",
  "type": "module",
  "main": "src/main.jsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "cd server && npx nodemon index.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "lint": "eslint src/ --ext .js,.jsx",
    "format": "prettier --write src/"
  },
  "keywords": [
    "puzzle",
    "games",
    "brain",
    "logic",
    "interactive",
    "braindasher",
    "react"
  ],
  "author": "PCCOE",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "gsap": "^3.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "prettier": "^3.0.0",
    "vite": "^5.0.0"
  }
}
